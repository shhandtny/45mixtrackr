15:{"metadata":[["$","title","0",{"children":"About — 45 Mix Trackr — 45 Mix Trackr"}],["$","meta","1",{"name":"description","content":"Learn how 45 Mix Trackr works. A free audio fingerprinting tool that identifies every song in a DJ mix and generates tracklists with album covers and SRT subtitle files."}],["$","meta","2",{"name":"keywords","content":"DJ mix identifier,identify songs in mix,mix tracklist generator,audio fingerprinting,DJ tracklist,song recognition,album cover downloader,SRT subtitle generator"}],["$","link","3",{"rel":"canonical","href":"https://www.45mixtrackr.com/about"}],["$","meta","4",{"property":"og:title","content":"45 Mix Trackr — Identify Every Song in Your Mix"}],["$","meta","5",{"property":"og:description","content":"Upload your DJ mix to identify every song. Get titles, artists, album covers, and an SRT subtitle file in minutes."}],["$","meta","6",{"property":"og:url","content":"https://www.45mixtrackr.com"}],["$","meta","7",{"property":"og:site_name","content":"45 Mix Trackr"}],["$","meta","8",{"property":"og:type","content":"website"}],["$","meta","9",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","10",{"name":"twitter:title","content":"45 Mix Trackr — Identify Every Song in Your Mix"}],["$","meta","11",{"name":"twitter:description","content":"Upload your DJ mix to identify every song. Get titles, artists, album covers, and an SRT subtitle file in minutes."}],["$","link","12",{"rel":"shortcut icon","href":"/favicon.svg"}],["$","link","13",{"rel":"icon","href":"/favicon.ico","type":"image/x-icon","sizes":"16x16"}],["$","link","14",{"rel":"icon","href":"/favicon.svg"}],["$","link","15",{"rel":"apple-touch-icon","href":"/favicon.svg"}],["$","$L1b","16",{}]],"error":null,"digest":"$undefined"}
