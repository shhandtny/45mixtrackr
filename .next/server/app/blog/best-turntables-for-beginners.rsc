1b:["$","p","17",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"The AT-LP120XUSB is a direct drive, manual turntable with a replaceable cartridge, pitch control, and USB output. It's the most popular mid-range turntable on the market and the go-to recommendation for aspiring DJs."}}]
1c:["$","p","18",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Pros:</strong>"}}]
