5:["$","$L10",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"How to Beatmatch Vinyl Records by Ear (Step-by-Step Guide)\",\"description\":\"Learn how to beatmatch vinyl records by ear — the foundational DJ skill. A step-by-step guide covering pitch adjustment, listening technique, and how to lock two records in sync.\",\"datePublished\":\"April 5, 2025\",\"author\":{\"@type\":\"Organization\",\"name\":\"45 Mix Trackr\",\"url\":\"https://www.45mixtrackr.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"45 Mix Trackr\",\"url\":\"https://www.45mixtrackr.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.45mixtrackr.com/blog/how-to-beatmatch-vinyl-records-by-ear\"}}"}}],["$","article",null,{"className":"max-w-2xl text-white","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-1 text-[#B3B3B3] hover:text-white text-sm mb-8 transition-colors","children":[["$","svg",null,{"className":"w-4 h-4","fill":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"d":"M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"}]}],"All posts"]}],["$","img",null,{"src":"/blog-images/how-to-beatmatch-vinyl-records-by-ear.jpg","alt":"How to Beatmatch Vinyl Records by Ear (Step-by-Step Guide)","className":"w-full h-64 object-cover rounded-xl mb-8 bg-spotify-surface"}],["$","h1",null,{"className":"text-3xl font-black leading-tight mb-3","children":"How to Beatmatch Vinyl Records by Ear (Step-by-Step Guide)"}],["$","div",null,{"className":"flex items-center gap-3 text-xs text-[#6B6B6B] mb-10","children":[["$","span",null,{"children":"April 5, 2025"}],["$","span",null,{"children":"•"}],["$","span",null,{"children":"8 min read"}]]}],["$","div",null,{"children":[["$","h2","0",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Introduction"}],["$","p","1",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Beatmatching is the art of aligning the tempo of two records so they play in perfect sync during a transition. Before digital sync buttons existed, every DJ had to do this by ear — and many argue it remains the most important skill in DJing. It develops your ear, your understanding of rhythm, and your feel for the music in ways that no algorithm can replicate."}}],["$","p","2",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"This guide walks you through beatmatching on vinyl from scratch — the method that's been used in clubs since the 1970s."}}],["$","hr","3",{"className":"border-[#282828] my-8"}],["$","h2","4",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"What You Need"}],["$","ul","5",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"Two turntables (direct drive recommended for consistent speed)"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"A DJ mixer with a crossfader and individual channel faders"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"Headphones with good bass response (you need to hear the kick drum clearly)"}}],["$","li","3",{"dangerouslySetInnerHTML":{"__html":"At least two copies of records with similar BPMs, or two different records you want to mix"}}]]}],["$","hr","6",{"className":"border-[#282828] my-8"}],["$","h2","7",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 1: Understand BPM and Pitch"}],["$","p","8",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"BPM (beats per minute) is the tempo of a track. House music typically runs 120–130 BPM. Hip-hop sits around 85–100 BPM. Drum and bass pushes 160–180 BPM."}}],"$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33"]}],"$L34","$L35"]}]]}]
12:["$","p","9",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Every direct drive turntable has a <strong class=\"text-white\">pitch fader</strong> — a slider that adjusts the platter speed from roughly -8% to +8%. Moving the fader up increases speed (raises BPM), moving it down slows it (lowers BPM)."}}]
13:["$","p","10",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Your goal: adjust the pitch fader on the incoming record until its BPM matches the record already playing."}}]
14:["$","hr","11",{"className":"border-[#282828] my-8"}]
15:["$","h2","12",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 2: Find the First Beat"}]
16:["$","p","13",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Cue up the incoming track to its first downbeat — the first kick drum hit at the start of a phrase. Gently hold the record still with your finger while the platter spins underneath, then release it exactly when you want it to start playing."}}]
17:["$","p","14",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"With practice, you'll learn to \"needle drop\" — placing the stylus precisely on the first beat without touching the record at all."}}]
18:["$","hr","15",{"className":"border-[#282828] my-8"}]
19:["$","h2","16",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 3: Listen and Compare in Headphones"}]
1a:["$","p","17",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Most DJ mixers have a headphone cue section that lets you monitor one channel privately while the crowd hears the other. Cue the incoming record in your headphones while the current track plays through the speakers."}}]
1b:["$","p","18",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Let both records play simultaneously in your headphones. You'll hear either:"}}]
1c:["$","ul","19",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">The beats lining up perfectly</strong> — you're in sync"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Phasing</strong> — a swirling, comb-filtered sound that means the beats are slightly offset but close in tempo"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">One kick rushing ahead of the other</strong> — the tempos are different"}}]]}]
1d:["$","hr","20",{"className":"border-[#282828] my-8"}]
1e:["$","h2","21",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 4: Adjust the Pitch Fader"}]
1f:["$","p","22",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"If the incoming record is running faster than the playing record, the beats will drift forward. Nudge the pitch fader slightly down to slow it."}}]
20:["$","p","23",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"If it's running slower, the beats drift backward. Push the pitch fader slightly up."}}]
21:["$","p","24",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Make very small adjustments — the pitch fader is sensitive. After each adjustment, let the records play for 4–8 bars to see if they stay in sync or drift again."}}]
22:["$","hr","25",{"className":"border-[#282828] my-8"}]
23:["$","h2","26",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 5: Fine-Tune with Hand Pressure"}]
24:["$","p","27",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Even after a good pitch match, the records may drift slightly due to minor variations in pressing weight or stylus drag. Use hand pressure to make micro-corrections:"}}]
25:["$","ul","28",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Lightly touch the label of the incoming record</strong> to slow it slightly"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Gently push the platter edge</strong> to speed it up"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Tap the spindle</strong> for very small forward nudges"}}]]}]
26:["$","p","29",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Professional DJs use these touches constantly during a mix — it's called \"riding\" the pitch."}}]
27:["$","hr","30",{"className":"border-[#282828] my-8"}]
28:["$","h2","31",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 6: Make the Transition"}]
29:["$","p","32",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Once the beats are locked, bring up the channel fader on the incoming record. The classic approach:"}}]
2a:["$","p","33",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"1. Mix in over 8 or 16 bars for a smooth blend"}}]
2b:["$","p","34",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"2. EQ out the bass on the incoming record before bringing it up fully (two kick drums fighting sounds muddy)"}}]
2c:["$","p","35",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"3. Cut the bass on the outgoing record as you raise it on the incoming one"}}]
2d:["$","p","36",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"4. Crossfade over 4 bars as the phrase completes"}}]
2e:["$","hr","37",{"className":"border-[#282828] my-8"}]
2f:["$","h2","38",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Tips for Faster Progress"}]
30:["$","ul","39",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Practice with the same record on both decks</strong> — identical BPMs mean you only need to match pitch drift, not BPM"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Count bars out loud</strong> — 4 beats per bar, 8 bars per phrase helps you anticipate transitions"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Record your practice sessions</strong> and listen back — you'll immediately hear where beats drifted"}}],["$","li","3",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Use 45 Mix Trackr</strong> on your practice recordings to review which tracks you used and how long each transition lasted"}}]]}]
31:["$","hr","40",{"className":"border-[#282828] my-8"}]
32:["$","h2","41",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Conclusion"}]
33:["$","p","42",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Beatmatching by ear is a skill that takes weeks to develop but lasts a lifetime. The ability to hear rhythm, feel tempo, and make micro-corrections in real time is what separates DJs from people who just press play. Start slow, practice daily, and trust your ears — they'll get sharper every session."}}]
