32:["$","ul","42",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Crossfader wear</strong> — move it back and forth rapidly and listen for crackling"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Channel fader travel</strong> — each fader should feel smooth and identical"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">EQ knobs</strong> — turn each fully and listen for crackling (pot wear)"}}],["$","li","3",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Phono ground connectors</strong> — make sure they're intact"}}],["$","li","4",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Power supply</strong> — original PSU preferred; third-party replacements can introduce hum"}}]]}]
