14:["$","h3","13",{"className":"text-white text-lg font-semibold mt-6 mb-2","children":"2. Metal Screw-In Adapters"}]
15:["$","p","14",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"A more secure option popular with club DJs. The metal construction adds weight and stability."}}]
16:["$","p","15",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Best for:</strong> Club environments, back-to-back sets"}}]
17:["$","p","16",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Downside:</strong> Slower to swap between records"}}]
18:["$","h3","17",{"className":"text-white text-lg font-semibold mt-6 mb-2","children":"3. Integrated Spindle Adapters"}]
19:["$","p","18",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Some DJ turntables (like the Technics SL-1200 series) come with a flip-up 45 RPM spindle adapter built directly into the platter. This is the cleanest solution — no loose parts to lose."}}]
1a:["$","p","19",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Best for:</strong> Serious vinyl DJs with compatible decks"}}]
