9:{"metadata":[["$","title","0",{"children":"Turntable Setup Guide for Beginners: Start Spinning Vinyl the Right Way — 45 Mix Trackr — 45 Mix Trackr"}],["$","meta","1",{"name":"description","content":"New to vinyl DJing? This beginner turntable setup guide covers everything — from choosing your first turntable to calibrating the tonearm, tracking force, and anti-skate."}],["$","meta","2",{"name":"keywords","content":"DJ mix identifier,identify songs in mix,mix tracklist generator,audio fingerprinting,DJ tracklist,song recognition,album cover downloader,SRT subtitle generator"}],["$","meta","3",{"property":"og:title","content":"45 Mix Trackr — Identify Every Song in Your Mix"}],["$","meta","4",{"property":"og:description","content":"Upload your DJ mix to identify every song. Get titles, artists, album covers, and an SRT subtitle file in minutes."}],["$","meta","5",{"property":"og:url","content":"https://www.45mixtrackr.com"}],["$","meta","6",{"property":"og:site_name","content":"45 Mix Trackr"}],["$","meta","7",{"property":"og:type","content":"website"}],["$","meta","8",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","9",{"name":"twitter:title","content":"45 Mix Trackr — Identify Every Song in Your Mix"}],["$","meta","10",{"name":"twitter:description","content":"Upload your DJ mix to identify every song. Get titles, artists, album covers, and an SRT subtitle file in minutes."}],["$","link","11",{"rel":"icon","href":"/favicon.ico","type":"image/x-icon","sizes":"16x16"}],["$","link","12",{"rel":"icon","href":"/icon.png?29e46ab3e521feee","type":"image/png","sizes":"512x512"}],["$","link","13",{"rel":"apple-touch-icon","href":"/apple-icon.png?8cc77d10a1a9629e","type":"image/png","sizes":"180x180"}],["$","$L3f","14",{}]],"error":null,"digest":"$undefined"}
