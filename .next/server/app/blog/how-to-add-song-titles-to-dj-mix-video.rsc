5:["$","$L10",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"How to Add Song Titles to a DJ Mix Video (SRT Method)\",\"description\":\"Learn how to add automatic song title overlays to your DJ mix YouTube video using an SRT subtitle file — works with DaVinci Resolve, Premiere Pro, and Final Cut Pro.\",\"datePublished\":\"April 15, 2025\",\"author\":{\"@type\":\"Organization\",\"name\":\"45 Mix Trackr\",\"url\":\"https://www.45mixtrackr.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"45 Mix Trackr\",\"url\":\"https://www.45mixtrackr.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.45mixtrackr.com/blog/how-to-add-song-titles-to-dj-mix-video\"}}"}}],["$","article",null,{"className":"max-w-2xl text-white","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-1 text-[#B3B3B3] hover:text-white text-sm mb-8 transition-colors","children":[["$","svg",null,{"className":"w-4 h-4","fill":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"d":"M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"}]}],"All posts"]}],["$","img",null,{"src":"/blog-images/how-to-add-song-titles-to-dj-mix-video.jpg","alt":"How to Add Song Titles to a DJ Mix Video (SRT Method)","className":"w-full h-64 object-cover rounded-xl mb-8 bg-spotify-surface"}],["$","h1",null,{"className":"text-3xl font-black leading-tight mb-3","children":"How to Add Song Titles to a DJ Mix Video (SRT Method)"}],["$","div",null,{"className":"flex items-center gap-3 text-xs text-[#6B6B6B] mb-10","children":[["$","span",null,{"children":"April 15, 2025"}],["$","span",null,{"children":"•"}],["$","span",null,{"children":"6 min read"}]]}],["$","div",null,{"children":[["$","h2","0",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Why Add Song Titles to Your Mix Video?"}],["$","p","1",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Viewers watching DJ mix videos on YouTube always want to know what's playing. Pinning a tracklist in the comments works, but it forces people to pause and scroll. A much better approach: show the song name directly on screen, fading in when each track starts."}}],["$","p","2",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"This is exactly what an SRT subtitle file does — and it takes minutes to set up once you have the file."}}],["$","hr","3",{"className":"border-[#282828] my-8"}],["$","h2","4",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 1: Generate Your SRT File"}],["$","p","5",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"The easiest way is to use <strong class=\"text-white\"><a href=\"/\" class=\"text-spotify-green hover:underline\">45 Mix Trackr</a></strong>, which identifies every song in your mix and generates a ready-to-use SRT file automatically."}}],["$","p","6",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"1. Upload your mix (MP3, MP4, WAV, M4A up to 500 MB)"}}],["$","p","7",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"2. Wait 2–5 minutes while the songs are identified"}}],["$","p","8",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"3. Download the ZIP — it contains your SRT file and all album cover artwork"}}],["$","p","9",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"The SRT file includes the song name and artist for every recognized track, with timestamps matching exactly when each song starts in your mix."}}],["$","hr","10",{"className":"border-[#282828] my-8"}],"$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L