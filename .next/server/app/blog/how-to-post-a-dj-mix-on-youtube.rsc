5:["$","$L10",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"How to Post a DJ Mix on YouTube (With Tracklist and Album Art)\",\"description\":\"A step-by-step guide to uploading a DJ mix to YouTube — including how to create a tracklist, add timestamps, use album art, and avoid copyright strikes.\",\"datePublished\":\"March 20, 2025\",\"author\":{\"@type\":\"Organization\",\"name\":\"45 Mix Trackr\",\"url\":\"https://www.45mixtrackr.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"45 Mix Trackr\",\"url\":\"https://www.45mixtrackr.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.45mixtrackr.com/blog/how-to-post-a-dj-mix-on-youtube\"}}"}}],["$","article",null,{"className":"max-w-2xl text-white","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-1 text-[#B3B3B3] hover:text-white text-sm mb-8 transition-colors","children":[["$","svg",null,{"className":"w-4 h-4","fill":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"d":"M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"}]}],"All posts"]}],["$","h1",null,{"className":"text-3xl font-black leading-tight mb-3","children":"How to Post a DJ Mix on YouTube (With Tracklist and Album Art)"}],["$","div",null,{"className":"flex items-center gap-3 text-xs text-[#6B6B6B] mb-10","children":[["$","span",null,{"children":"March 20, 2025"}],["$","span",null,{"children":"•"}],["$","span",null,{"children":"7 min read"}]]}],["$","div",null,{"children":[["$","h2","0",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Introduction"}],["$","p","1",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"YouTube is one of the best platforms for sharing DJ mixes. It offers long-form video support, a massive audience, and strong discovery through search. But uploading a DJ mix without a proper tracklist, timestamps, or artwork looks unprofessional — and submitting without the right preparation can result in a copyright claim or block."}}],["$","p","2",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"This guide walks you through posting a DJ mix on YouTube the right way."}}],["$","hr","3",{"className":"border-[#282828] my-8"}],["$","h2","4",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 1: Identify Every Track in Your Mix"}],["$","p","5",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Before you upload anything, you need a complete tracklist. This is the most time-consuming step — but it's essential for the description, timestamps, and legal disclosure."}}],["$","p","6",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"If you recorded your set live and didn't track what you played, <strong class=\"text-white\">45 Mix Trackr</strong> can identify every song automatically. Upload your audio file and it returns the title, artist, and timestamp for every recognized track — usually within a few minutes for a one-hour mix."}}],["$","hr","7",{"className":"border-[#282828] my-8"}],["$","h2","8",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 2: Record or Export Your Mix"}],["$","p","9",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Export your mix as a high-quality audio file:"}}],["$","ul","10",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Format:</strong> WAV or high-bitrate MP3 (320kbps minimum)"}}],"$L12","$L13"]}],"$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d"]}],"$L3e","$L3f"]}]]}]
12:["$","li","1",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Length:</strong> YouTube supports videos up to 12 hours on verified accounts"}}]
13:["$","li","2",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Normalization:</strong> Aim for -1dB peak to avoid clipping on YouTube's audio processing"}}]
14:["$","hr","11",{"className":"border-[#282828] my-8"}]
15:["$","h2","12",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 3: Create the Video"}]
16:["$","p","13",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"YouTube requires a video file, not just audio. Options:"}}]
17:["$","p","14",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Static image video:</strong>"}}]
18:["$","p","15",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"The simplest approach. Use a single image (your mix artwork, a photo, or a DJ photo) combined with your audio file. Tools:"}}]
19:["$","ul","16",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">DaVinci Resolve</strong> (free) — import audio + image, export as MP4"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">iMovie</strong> — drag in both, export"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Adobe Premiere</strong> — professional option"}}]]}]
1a:["$","p","17",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Tracklist visualization:</strong>"}}]
1b:["$","p","18",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"More engaging. Use a tool like Adobe Express or Canva to create a video that shows the tracklist scrolling as each song plays."}}]
1c:["$","p","19",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">SRT subtitles:</strong>"}}]
1d:["$","p","20",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">45 Mix Trackr</strong> generates an SRT subtitle file with each song's title and artist timed to when they appear in the mix. Import this into DaVinci Resolve or Premiere and the song names will appear as on-screen text automatically throughout the video."}}]
1e:["$","hr","21",{"className":"border-[#282828] my-8"}]
1f:["$","h2","22",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 4: Write the Description with Timestamps"}]
20:["$","p","23",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"A good YouTube description dramatically increases discoverability. Format it like this:"}}]
21:["$","p","24",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    [Mix Title] — [Your DJ Name]"}}]
22:["$","p","25",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    Tracklist:"}}]
23:["$","p","26",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    0:00 Artist - Track Title"}}]
24:["$","p","27",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    3:24 Artist - Track Title"}}]
25:["$","p","28",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    7:11 Artist - Track Title"}}]
26:["$","p","29",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    ..."}}]
27:["$","p","30",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    Recorded live at [Venue/Location] on [Date]"}}]
28:["$","p","31",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    Follow me:"}}]
29:["$","p","32",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    Instagram: @yourhandle"}}]
2a:["$","p","33",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"    Mixcloud: mixcloud.com/yourname"}}]
2b:["$","p","34",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"YouTube automatically converts timestamps in the 0:00 format into clickable chapter markers in the video timeline. This is extremely valuable for viewers who want to find specific tracks."}}]
2c:["$","hr","35",{"className":"border-[#282828] my-8"}]
2d:["$","h2","36",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 5: Create Album Artwork"}]
2e:["$","p","37",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"A strong thumbnail is critical for YouTube performance. Use:"}}]
2f:["$","ul","38",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"Your DJ name prominently"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"The genre or mood of the mix"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"A high-quality image (your photo, abstract art, or a relevant scene)"}}],["$","li","3",{"dangerouslySetInnerHTML":{"__html":"Minimum 1280×720 pixels, ideally 1920×1080"}}]]}]
30:["$","p","39",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">45 Mix Trackr</strong> downloads the album covers for every recognized track in your mix. These can be used as collage elements in your thumbnail artwork."}}]
31:["$","hr","40",{"className":"border-[#282828] my-8"}]
32:["$","h2","41",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 6: Handle Copyright"}]
33:["$","p","42",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"DJ mixes on YouTube almost always receive Content ID claims from rights holders. This is different from a copyright strike — a claim means the rights holder can run ads on your video or block it in specific countries."}}]
34:["$","p","43",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">To minimize issues:</strong>"}}]
35:["$","ul","44",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"Always include a full tracklist in the description — this demonstrates good faith"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"Consider joining a DJ pools or licensing services if you publish regularly"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"Some rights holders allow DJ mixes without blocking — house and electronic music labels tend to be more permissive than major pop labels"}}]]}]
36:["$","p","45",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Never dispute a legitimate Content ID claim</strong> — false disputes escalate to manual reviews and potential channel strikes."}}]
37:["$","hr","46",{"className":"border-[#282828] my-8"}]
38:["$","h2","47",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Step 7: Optimize for Search"}]
39:["$","p","48",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"YouTube is the world's second largest search engine. Optimize your upload:"}}]
3a:["$","ul","49",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Title:</strong> Include genre, year, mix number, and your name (\"Deep House Mix 2025 — Vol. 12\")"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Tags:</strong> Artist names, genre tags, \"DJ mix\", \"tracklist\""}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Category:</strong> Music"}}],["$","li","3",{"dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Description keywords:</strong> Include genre, mood, tempo, occasion"}}]]}]
3b:["$","hr","50",{"className":"border-[#282828] my-8"}]
3c:["$","h2","51",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Conclusion"}]
3d:["$","p","52",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"A well-prepared YouTube upload — complete tracklist, timestamps, artwork, and a properly formatted description — is the difference between a mix that disappears and one that builds an audience over time. Use 45 Mix Trackr to automate the hardest part (building the tracklist), create compelling artwork with the album covers it downloads, and use the SRT file for automatic on-screen track credits."}}]
