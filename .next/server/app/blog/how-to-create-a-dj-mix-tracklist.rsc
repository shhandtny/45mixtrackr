37:["$","ul","45",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"Start timing from the first audible beat, not from the beginning of the file (which may have silence)"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"For blended transitions, use the moment when the new track becomes the dominant element"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"Round to the nearest second — precision to milliseconds isn't necessary"}}]]}]
