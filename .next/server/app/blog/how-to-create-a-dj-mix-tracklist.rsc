30:["$","p","38",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"Some tracks — especially dubplates, acetates, unreleased tracks, or very obscure pressings — won't be in any fingerprinting database. Options:"}}]
31:["$","p","39",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"1. <strong class=\"text-white\">Search SoundHound or Shazam</strong> manually on that segment"}}]
