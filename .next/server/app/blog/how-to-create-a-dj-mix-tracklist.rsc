5:["$","$L10",null,{"children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"How to Create a DJ Mix Tracklist (The Right Way)\",\"description\":\"Learn how to build a proper DJ mix tracklist — manually and automatically. Includes timestamps, formatting tips, and how to post tracklists on YouTube, Mixcloud, and Instagram.\",\"datePublished\":\"March 12, 2025\",\"author\":{\"@type\":\"Organization\",\"name\":\"45 Mix Trackr\",\"url\":\"https://www.45mixtrackr.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"45 Mix Trackr\",\"url\":\"https://www.45mixtrackr.com\"},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://www.45mixtrackr.com/blog/how-to-create-a-dj-mix-tracklist\"}}"}}],["$","article",null,{"className":"max-w-2xl text-white","children":[["$","$L11",null,{"href":"/blog","className":"inline-flex items-center gap-1 text-[#B3B3B3] hover:text-white text-sm mb-8 transition-colors","children":[["$","svg",null,{"className":"w-4 h-4","fill":"currentColor","viewBox":"0 0 24 24","children":["$","path",null,{"d":"M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"}]}],"All posts"]}],["$","img",null,{"src":"/blog-images/how-to-create-a-dj-mix-tracklist.jpg","alt":"How to Create a DJ Mix Tracklist (The Right Way)","className":"w-full h-64 object-cover rounded-xl mb-8 bg-spotify-surface"}],["$","h1",null,{"className":"text-3xl font-black leading-tight mb-3","children":"How to Create a DJ Mix Tracklist (The Right Way)"}],["$","div",null,{"className":"flex items-center gap-3 text-xs text-[#6B6B6B] mb-10","children":[["$","span",null,{"children":"March 12, 2025"}],["$","span",null,{"children":"•"}],["$","span",null,{"children":"6 min read"}]]}],["$","div",null,{"children":[["$","h2","0",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Introduction"}],["$","p","1",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"A tracklist is the written record of every song in a DJ mix — title, artist, and ideally the timestamp where each track starts. It's how listeners find the songs they love, how you get credit for your curation, and how rights holders track usage of their music. A well-formatted tracklist is one of the most important parts of sharing a mix online."}}],["$","hr","2",{"className":"border-[#282828] my-8"}],["$","h2","3",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Why Tracklists Matter"}],["$","p","4",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">For listeners:</strong> When a song makes someone feel something at the 47-minute mark of your mix, they want to know what it is. A tracklist with timestamps lets them find it instantly."}}],["$","p","5",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">For discoverability:</strong> YouTube, Mixcloud, and Beatport each index tracklist content for search. A mix tagged with \"Floating Points\", \"Four Tet\", and \"Burial\" will surface in searches for those artists."}}],["$","p","6",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">For rights management:</strong> Most streaming platforms use tracklist data to process royalty payments to rights holders. Providing accurate information is both ethical and helps keep your mix online."}}],["$","p","7",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">For your own archive:</strong> After years of DJing, your old tracklists become a valuable record of your development as a selector."}}],"$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f"]}],"$L40","$L41"]}]]}]
12:["$","hr","8",{"className":"border-[#282828] my-8"}]
13:["$","h2","9",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Method 1: Track Manually During the Mix"}]
14:["$","p","10",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"The most accurate approach. Keep a notepad (physical or digital) at your side while mixing and write down each track as you play it. Include the timestamp when you drop each track."}}]
15:["$","p","11",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">Tips:</strong>"}}]
16:["$","ul","12",{"className":"list-disc list-outside ml-5 space-y-1 text-[#B3B3B3] leading-relaxed my-3","children":[["$","li","0",{"dangerouslySetInnerHTML":{"__html":"Use a timer app on your phone that you start at the beginning of the recording"}}],["$","li","1",{"dangerouslySetInnerHTML":{"__html":"Write the track name as you cue it up, not after you've mixed it in — it's easy to forget in the moment"}}],["$","li","2",{"dangerouslySetInnerHTML":{"__html":"Note any edits, loops, or acapellas you used"}}]]}]
17:["$","hr","13",{"className":"border-[#282828] my-8"}]
18:["$","h2","14",{"className":"text-white text-2xl font-bold mt-10 mb-4","children":"Method 2: Use Audio Fingerprinting (Automated)"}]
19:["$","p","15",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"For live sets where you were too focused on the mix to take notes, or for old recordings where you've forgotten the tracklist, audio fingerprinting is the fastest solution."}}]
1a:["$","p","16",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"<strong class=\"text-white\">45 Mix Trackr</strong> automates this entirely:"}}]
1b:["$","p","17",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"1. Upload your mix file (MP3, WAV, MP4, M4A up to 500MB)"}}]
1c:["$","p","18",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"2. The tool splits it into segments and sends each to ACRCloud's fingerprinting database"}}]
1d:["$","p","19",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"3. Within minutes, you get a complete tracklist with song titles, artists, album covers, and timestamps"}}]
1e:["$","p","20",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"4. Download the SRT subtitle file — timestamps are already formatted correctly for YouTube"}}]
1f:["$","hr","21",{"className":"border-[#282828] my-8"}]
