33:["$","p","41",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"3. <strong class=\"text-white\">Contact the DJ</strong> directly — many DJs are happy to share their tracklists if asked politely"}}]
34:["$","p","42",{"className":"text-[#B3B3B3] leading-relaxed my-3","dangerouslySetInnerHTML":{"__html":"4. <strong class=\"text-white\">Label it as \"Unknown\"</strong> rather than leaving it blank — it's better to be honest"}}]
